<hc:Window x:Class="ReNamer.Views.FileNameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:ReNamer.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:FileNameInputDialogViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="300" Height="180">
    <StackPanel Margin="20">
        <TextBlock Text="{Binding Tips}" Margin="0,0,0,10"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                 hc:InfoElement.Placeholder="不能包含 \ / : * ? &lt; > |"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="确定" Command="{Binding ConfirmCommand}" 
                    IsDefault="True" Width="60" Margin="0,0,10,0"/>
            <Button Content="取消" Command="{Binding CancelCommand}" 
                    IsCancel="True" Width="60"/>
        </StackPanel>
    </StackPanel>
</hc:Window>

<hc:Window
    x:Class="ReNamer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behavior="clr-namespace:ReNamer.Behaviors"
    xmlns:controls="clr-namespace:ReNamer.Controls"
    xmlns:converters="clr-namespace:ReNamer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ReNamer.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ReNamer.ViewModels"
    Title="{Binding Title}"
    Width="800"
    Height="700"
    MinWidth="400"
    MinHeight="400"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    AllowDrop="True"
    Icon="/Images/lets-icons--rename.png"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:Window.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

        <Style BasedOn="{StaticResource DataGrid.Small}" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="RowHeight" Value="26" />
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource DarkDefaultBrush}" />
        </Style>
        <Style BasedOn="{StaticResource StatusBarBaseStyle}" TargetType="StatusBar" />
        <Style BasedOn="{StaticResource StatusBarItemBaseStyle}" TargetType="StatusBarItem" />
        <Style BasedOn="{StaticResource ProgressBarBaseStyle}" TargetType="ProgressBar" />

        <Style BasedOn="{StaticResource TextBoxBaseStyle}" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style BasedOn="{StaticResource CheckBoxBaseStyle}" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </hc:Window.Resources>
    <!--  窗口：触发器  -->
    <i:Interaction.Triggers>
        <!--  拖拽悬浮事件 (隧道)  -->
        <i:EventTrigger EventName="PreviewDragOver">
            <i:InvokeCommandAction Command="{Binding PreviewDragOverFilesCommand}" PassEventArgsToCommand="True" />
        </i:EventTrigger>
        <!--  拖拽放置事件 (隧道)  -->
        <i:EventTrigger EventName="PreviewDrop">
            <i:InvokeCommandAction Command="{Binding PreviewDroppedFilesCommand}" PassEventArgsToCommand="True" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" MinHeight="150" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5*" MinHeight="200" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--  规则列表  -->
        <Grid Grid.Row="0" Margin="8,4,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Command="{Binding AddRuleCommand}"
                    Content="添加规则">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ButtonPrimary}" TargetType="Button" />
                    </Button.Style>
                </Button>
                <hc:Divider Grid.Column="1" Orientation="Vertical" />
                <!--  预设  -->
                <Grid Grid.Column="2" Margin="6,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <hc:ComboBox
                        x:Name="PresetCombo"
                        Grid.Column="0"
                        Width="160"
                        hc:InfoElement.Title="预设："
                        hc:InfoElement.TitlePlacement="Left"
                        ItemsSource="{Binding Presets}"
                        SelectedItem="{Binding CurrentPreset}">
                        <hc:ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}">
                                    <!--  给选项绑定行为触发器  -->
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction Command="{Binding DataContext.ReloadPresetCommand, RelativeSource={RelativeSource AncestorType=ComboBox}}" CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBlock>
                            </DataTemplate>
                        </hc:ComboBox.ItemTemplate>
                    </hc:ComboBox>
                    <Button
                        Grid.Column="1"
                        Margin="4,0,0,0"
                        Command="{Binding SavePresetCommand}"
                        Content="保存">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ButtonSuccess}" TargetType="Button" />
                        </Button.Style>
                    </Button>
                    <Button
                        Grid.Column="2"
                        Margin="4,0,0,0"
                        Command="{Binding SaveAsPresetCommand}"
                        Content="另存为">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ButtonInfo}" TargetType="Button" />
                        </Button.Style>
                    </Button>
                    <Button
                        Grid.Column="3"
                        Margin="4,0,0,0"
                        Command="{Binding RenamePresetCommand}"
                        Content="重命名">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ButtonPrimary}" TargetType="Button" />
                        </Button.Style>
                    </Button>
                    <Button
                        Grid.Column="4"
                        Margin="4,0,0,0"
                        Command="{Binding RemovePresetCommand}"
                        Content="删除">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ButtonDanger}" TargetType="Button" />
                        </Button.Style>
                    </Button>
                </Grid>
                <Button
                    Grid.Column="4"
                    Command="{Binding ClearRuleCommand}"
                    Content="清空规则">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ButtonDanger}" TargetType="Button" />
                    </Button.Style>
                </Button>
            </Grid>
            <!--  规则列表  -->
            <DataGrid
                x:Name="RuleDataGrid"
                Grid.Row="1"
                Margin="0,4,0,0"
                dd:DragDrop.DropHandler="{Binding}"
                dd:DragDrop.IsDragSource="True"
                dd:DragDrop.IsDropTarget="True"
                hc:DataGridAttach.ShowRowNumber="True"
                CanUserAddRows="False"
                CanUserDeleteRows="True"
                CanUserSortColumns="False"
                ItemsSource="{Binding Rules}">
                <DataGrid.Resources>
                    <Style BasedOn="{StaticResource DataGridCellStyle}" TargetType="DataGridCell">
                        <!--  解决点击超宽单元格时候水平滚动条跳动定位该单元格的现象  -->
                        <EventSetter Event="RequestBringIntoView" Handler="OnRequestBringIntoView" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <!--  Row样式  -->
                    <Style BasedOn="{StaticResource DataGridRowStyle}" TargetType="DataGridRow">
                        <Setter Property="Tag" Value="{Binding DataContext, ElementName=RuleDataGrid}" />
                        <Setter Property="Margin" Value="0.3" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <ContextMenu.Style>
                                        <Style BasedOn="{StaticResource ContextMenu.Small}" TargetType="ContextMenu" />
                                    </ContextMenu.Style>
                                    <!--  编辑规则  -->
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.EditRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="编辑" />
                                    <!--  移除规则  -->
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="移除" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.ClearRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="清空列表" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <!--  行首样式  -->
                <DataGrid.RowHeaderStyle>
                    <Style BasedOn="{StaticResource DataGridRowHeaderStyle}" TargetType="DataGridRowHeader">
                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="Padding" Value="4,2" />
                        <Setter Property="Width" Value="Auto" />
                    </Style>
                </DataGrid.RowHeaderStyle>
                <!--  触发器  -->
                <i:Interaction.Triggers>
                    <!--  空白处左键双击  -->
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding DataGridBlankAreaDoubleClickCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                    <!--  空白处左键单击  -->
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding RuleDataGridMouseDownCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <i:Interaction.Behaviors>
                    <behavior:DataGridSelectedItemsBehavior SelectedItems="{Binding SelectedRules}" />
                </i:Interaction.Behaviors>
                <!--  表格空白处右键菜单  -->
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ContextMenu.Style>
                            <Style BasedOn="{StaticResource ContextMenu.Small}" TargetType="ContextMenu" />
                        </ContextMenu.Style>
                        <MenuItem Command="{Binding AddRuleCommand}" Header="添加规则" />
                        <MenuItem Command="{Binding RemoveRuleCommand}" Header="移除选中项" />
                        <MenuItem Command="{Binding ClearRuleCommand}" Header="清空列表" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="Auto" Header="#">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        VerticalContentAlignment="Center"
                                        Command="{Binding DataContext.ToggleRuleEnableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        IsChecked="{Binding Enable, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding TypeName}"
                        Header="规则"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Description}"
                        Header="说明"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <!--  拖拽线  -->
        <GridSplitter
            Grid.Row="1"
            Height="2"
            Margin="8,-1,8,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Rows" />
        <!--  文件列表  -->
        <Grid Grid.Row="2" Margin="8,4,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <!--  功能按钮  -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Command="{Binding ApplyRenameCommand}"
                    Content="重命名">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ButtonSuccess}" TargetType="Button" />
                    </Button.Style>
                </Button>
                <Button
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    Command="{Binding PreviewRenameCommand}"
                    Content="预览">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ButtonInfo}" TargetType="Button" />
                    </Button.Style>
                    <Button.CommandParameter>
                        <s:Boolean xmlns:s="clr-namespace:System;assembly=mscorlib">True</s:Boolean>
                    </Button.CommandParameter>
                </Button>
                <hc:Divider Grid.Column="3" Orientation="Vertical" />
                <Grid
                    Grid.Column="4"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="过滤器：" />
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Column="0"
                            Content="文件："
                            IsChecked="{Binding CurrentPreset.Filters.File.Enable}" />
                        <hc:TextBox
                            Grid.Column="1"
                            Width="150"
                            hc:InfoElement.Placeholder="输入正则表达式"
                            hc:InfoElement.ShowClearButton="True"
                            Text="{Binding CurrentPreset.Filters.File.Regex, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Grid Grid.Column="2" Margin="6,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Column="0"
                            Content="目录："
                            IsChecked="{Binding CurrentPreset.Filters.Folder.Enable}" />
                        <hc:TextBox
                            Grid.Column="1"
                            Width="150"
                            hc:InfoElement.Placeholder="输入正则表达式"
                            hc:InfoElement.ShowClearButton="True"
                            Text="{Binding CurrentPreset.Filters.Folder.Regex, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
                <Button
                    Grid.Column="5"
                    Command="{Binding ClearFileCommand}"
                    Content="清空列表">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ButtonDanger}" TargetType="Button" />
                    </Button.Style>
                </Button>
            </Grid>
            <!--  文件列表  -->
            <DataGrid
                x:Name="FileDataGrid"
                Grid.Row="1"
                Margin="0,4,0,0"
                dd:DragDrop.DropHandler="{Binding}"
                dd:DragDrop.IsDragSource="True"
                dd:DragDrop.IsDropTarget="True"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="True"
                ItemsSource="{Binding Files}"
                VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingStackPanel.IsVirtualizing="True">
                <DataGrid.Resources>
                    <Style BasedOn="{StaticResource DataGridCellStyle}" TargetType="DataGridCell">
                        <!--  解决点击超宽单元格时候水平滚动条跳动定位该单元格的现象  -->
                        <EventSetter Event="RequestBringIntoView" Handler="OnRequestBringIntoView" />
                    </Style>
                    <Style
                        x:Key="TextOverflowStyle"
                        BasedOn="{StaticResource TextBlockBaseStyle}"
                        TargetType="TextBlock">
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <Setter Property="HorizontalAlignment" Value="Left" />
                    </Style>
                </DataGrid.Resources>
                <!--  Row样式  -->
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource DataGridRowStyle}" TargetType="DataGridRow">
                        <Setter Property="Tag" Value="{Binding DataContext, ElementName=FileDataGrid}" />
                        <Setter Property="Margin" Value="0.3" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <ContextMenu.Style>
                                        <Style BasedOn="{StaticResource ContextMenu.Small}" TargetType="ContextMenu" />
                                    </ContextMenu.Style>
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="打开文件" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.OpenFileAndSelectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="在资源管理中定位" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="移除" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.ClearFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding .}"
                                        Header="清空列表" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <!--  触发器  -->
                <i:Interaction.Triggers>
                    <!--  空白处左键单击  -->
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding FileDataGridMouseDownCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <i:Interaction.Behaviors>
                    <behavior:DataGridSelectedItemsBehavior SelectedItems="{Binding SelectedFiles}" />
                </i:Interaction.Behaviors>
                <!--  表格空白处右键菜单  -->
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ContextMenu.Style>
                            <Style BasedOn="{StaticResource ContextMenu.Small}" TargetType="ContextMenu" />
                        </ContextMenu.Style>
                        <MenuItem Command="{Binding RemoveFileCommand}" Header="移除选中项" />
                        <MenuItem Command="{Binding ClearFileCommand}" Header="清空列表" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn
                        Width="60"
                        MinWidth="60"
                        MaxWidth="60"
                        CanUserSort="False"
                        Header="状态">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Command="{Binding DataContext.ToggleFileEnableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" IsChecked="{Binding Enable, UpdateSourceTrigger=PropertyChanged}">
                                    <CheckBox.Style>
                                        <Style BasedOn="{StaticResource CheckBoxBaseStyle}" TargetType="CheckBox">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="2,0,0,0" />
                                        </Style>
                                    </CheckBox.Style>
                                    <TextBlock Grid.Column="0">
                                        <TextBlock.Style>
                                            <Style BasedOn="{StaticResource TextBlockBaseStyle}" TargetType="TextBlock">
                                                <!--  默认值  -->
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <!--  当 NewPathExist 为 True 时  -->
                                                    <DataTrigger Binding="{Binding IsOK}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Text" Value="✔" />
                                                        <Setter Property="Foreground" Value="#00A000" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Text" Value="❌" />
                                                        <Setter Property="Foreground" Value="Red" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="Auto"
                        MinWidth="100"
                        Binding="{Binding Name}"
                        ElementStyle="{StaticResource TextOverflowStyle}"
                        Header="文件名"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="Auto"
                        MinWidth="100"
                        Binding="{Binding NewName}"
                        CanUserSort="False"
                        Header="新文件名">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource TextOverflowStyle}" TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOK}" Value="True">
                                        <Setter Property="Foreground" Value="#00A000" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                        <Setter Property="Foreground" Value="Red" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="Auto"
                        MinWidth="50"
                        MaxWidth="60"
                        Binding="{Binding Ext}"
                        ElementStyle="{StaticResource TextOverflowStyle}"
                        Header="扩展名"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="2*"
                        MinWidth="100"
                        Binding="{Binding Dir}"
                        ElementStyle="{StaticResource TextOverflowStyle}"
                        Header="目录"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="*"
                        MinWidth="100"
                        Binding="{Binding Path}"
                        ElementStyle="{StaticResource TextOverflowStyle}"
                        Header="源路径"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <DockPanel Grid.Row="3">
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" />
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="文件总数: " />
                        <TextBlock Text="{Binding Files.Count}" />
                    </StackPanel>
                </StatusBarItem>
                <Separator Visibility="{Binding SelectedFiles.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                <StatusBarItem Visibility="{Binding SelectedFiles.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedFiles.Count, StringFormat={}已选中 {0} 个文件}" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalContentAlignment="Right">
                    <StatusBarItem.Style>
                        <Style BasedOn="{StaticResource StatusBarItemBaseStyle}" TargetType="StatusBarItem">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgressVisible}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!--  淡出动画 1s 后开始持续0.5s  -->
                                                <DoubleAnimation
                                                    BeginTime="0:0:1"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0"
                                                    Duration="0:0:0.5" />
                                                <!--  1.5后隐藏  -->
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:1.5" Value="{x:Static Visibility.Collapsed}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!--  显示时立即出现  -->
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1"
                                                    Duration="0" />
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StatusBarItem.Style>
                    <ProgressBar
                        Width="100"
                        Height="15"
                        Value="{Binding ProgressValue}" />
                </StatusBarItem>
            </StatusBar>
        </DockPanel>
    </Grid>
</hc:Window>

<hc:Window x:Class="ReNamer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:controls="clr-namespace:ReNamer.Controls"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:ReNamer.ViewModels"
        xmlns:helper="clr-namespace:ReNamer.Helpers"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        Title="批量重命名工具" 
        Height="700" Width="800"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen" 
        Icon="/Images/lets-icons--rename.png"
        AllowDrop="True"
        >
    <hc:Window.DataContext>
        <!-- 绑定 VM -->
        <vm:MainWindowViewModel />
    </hc:Window.DataContext>
    <hc:Window.Resources>
        <Style TargetType="DataGrid" BasedOn="{StaticResource DataGrid.Small}">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeight" Value="26"/>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource DarkDefaultBrush}" />
        </Style>
        <Style TargetType="StatusBar" BasedOn="{StaticResource StatusBarBaseStyle}"></Style>
        <Style TargetType="StatusBarItem" BasedOn="{StaticResource StatusBarItemBaseStyle}"></Style>
        <Style TargetType="ProgressBar" BasedOn="{StaticResource ProgressBarBaseStyle}"></Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource CheckBoxBaseStyle}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </hc:Window.Resources>
    <!-- 窗口：触发器 -->
    <i:Interaction.Triggers>
        <!-- 拖拽悬浮事件 (隧道) -->
        <i:EventTrigger EventName="PreviewDragOver">
            <i:InvokeCommandAction 
                Command="{Binding PreviewDragOverFilesCommand}" 
                PassEventArgsToCommand="True" />
        </i:EventTrigger>
        <!-- 拖拽放置事件 (隧道) -->
        <i:EventTrigger EventName="PreviewDrop">
            <i:InvokeCommandAction 
                Command="{Binding PreviewDroppedFilesCommand}" 
                PassEventArgsToCommand="True" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" MinHeight="150" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*" MinHeight="200"/>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--规则列表-->
        <Grid Grid.Row="0" Margin="8,4,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"  Content="添加规则" Command="{Binding AddRuleCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}"></Style>
                    </Button.Style>
                </Button>
                <hc:Divider Grid.Column="1" Orientation="Vertical" />
                <!-- 预设 -->
                <Grid Grid.Column="2" Margin="6,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <hc:ComboBox Grid.Column="0" 
                                x:Name="PresetCombo"
                                ItemsSource="{Binding Presets}" 
                                SelectedItem="{Binding CurrentPreset}"
                                Width="160" 
                                hc:InfoElement.Title="预设："
                                hc:InfoElement.TitlePlacement="Left">
                        <hc:ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}">
                                    <!-- 给选项绑定行为触发器 -->
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction
                                                Command="{Binding DataContext.ReloadPresetCommand,
                                                          RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBlock>
                            </DataTemplate>
                        </hc:ComboBox.ItemTemplate>
                    </hc:ComboBox>
                    <Button Grid.Column="1" Content="保存" Margin="4,0,0,0" Command="{Binding SavePresetCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonSuccess}"></Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="2" Content="另存为" Margin="4,0,0,0" Command="{Binding SaveAsPresetCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonInfo}"></Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="3" Content="重命名" Margin="4,0,0,0" Command="{Binding RenamePresetCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}"></Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="4" Content="删除" Margin="4,0,0,0" Command="{Binding RemovePresetCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonDanger}"></Style>
                        </Button.Style>
                    </Button>
                </Grid>
                <Button Grid.Column="4"  Content="清空规则" Command="{Binding ClearRuleCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonDanger}"></Style>
                    </Button.Style>
                </Button>
            </Grid>
            <!--规则列表-->
            <DataGrid Grid.Row="1" x:Name="RuleDataGrid" 
                      ItemsSource="{Binding Rules}" 
                      helper:DataGridSelectionHelper.SelectedItems="{Binding SelectedRules}"
                      CanUserSortColumns="False" CanUserAddRows="False" CanUserDeleteRows="True"
                      hc:DataGridAttach.ShowRowNumber="True"
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      dd:DragDrop.DropHandler="{Binding}"
                      Margin="0,4,0,0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}">
                        <!-- 解决点击超宽单元格时候水平滚动条跳动定位该单元格的现象 -->
                        <EventSetter Event="RequestBringIntoView" Handler="OnRequestBringIntoView"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <!-- Row样式 -->
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                        <Setter Property="Tag" Value="{Binding DataContext, ElementName=RuleDataGrid}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <ContextMenu.Style>
                                        <Style TargetType="ContextMenu" BasedOn="{StaticResource  ContextMenu.Small}"></Style>
                                    </ContextMenu.Style>
                                    <!-- 编辑规则 -->
                                    <MenuItem Header="编辑" 
                                              Command="{Binding PlacementTarget.Tag.EditRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding .}"/>
                                    <!-- 移除规则 -->
                                    <MenuItem Header="移除" 
                                              Command="{Binding PlacementTarget.Tag.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding .}"/>
                                    <MenuItem Header="清空列表" 
                                              Command="{Binding PlacementTarget.Tag.ClearRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding .}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <!-- 行首样式 -->
                <DataGrid.RowHeaderStyle>
                    <Style TargetType="DataGridRowHeader" BasedOn="{StaticResource DataGridRowHeaderStyle}">
                        <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="Width" Value="Auto"/>
                    </Style>
                </DataGrid.RowHeaderStyle>
                <!-- 触发器 -->
                <i:Interaction.Triggers>
                    <!-- 空白处左键双击 -->
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding DataGridBlankAreaDoubleClickCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                    <!-- 空白处左键单击-->
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding RuleDataGridMouseDownCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <!-- 表格空白处右键菜单 -->
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ContextMenu.Style>
                            <Style TargetType="ContextMenu" BasedOn="{StaticResource  ContextMenu.Small}"></Style>
                        </ContextMenu.Style>
                        <MenuItem Header="添加规则" Command="{Binding AddRuleCommand}" />
                        <MenuItem Header="移除选中项" Command="{Binding RemoveRuleCommand}" />
                        <MenuItem Header="清空列表" Command="{Binding ClearRuleCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="#" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding Enable, UpdateSourceTrigger=PropertyChanged}" 
                                              Command="{Binding DataContext.ToggleRuleEnableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              VerticalContentAlignment="Center" 
                                              />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="规则"  Width="Auto" Binding="{Binding TypeName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="说明"  Width="Auto" Binding="{Binding Description}" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <!--拖拽线-->
        <GridSplitter Grid.Row="1" Height="2" Margin="8,-1,8,0"  HorizontalAlignment="Stretch" VerticalAlignment="Bottom" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"/>
        <!-- 文件列表 -->
        <Grid Grid.Row="2" Margin="8,4,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <!--功能按钮-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="重命名" Command="{Binding ApplyRenameCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonSuccess}"></Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="预览" Command="{Binding PreviewRenameCommand}"  Margin="6,0,0,0" >
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonInfo}"></Style>
                    </Button.Style>
                    <Button.CommandParameter>
                        <s:Boolean xmlns:s="clr-namespace:System;assembly=mscorlib">True</s:Boolean>
                    </Button.CommandParameter>
                </Button>
                <hc:Divider Grid.Column="3" Orientation="Vertical" />
                <Grid Grid.Column="4" Margin="4,0,0,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="过滤器：" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="文件：" IsChecked="{Binding CurrentPreset.Filters.File.Enable}" />
                        <hc:TextBox Grid.Column="1" Width="150" 
                                 hc:InfoElement.Placeholder="输入正则表达式"
                                 hc:InfoElement.ShowClearButton="True"
                                 Text="{Binding CurrentPreset.Filters.File.Regex,UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Grid Grid.Column="2" Margin="6,0,0,0" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="目录：" IsChecked="{Binding CurrentPreset.Filters.Folder.Enable}"/>
                        <hc:TextBox Grid.Column="1" Width="150" 
                                    hc:InfoElement.Placeholder="输入正则表达式"
                                    hc:InfoElement.ShowClearButton="True"
                                    Text="{Binding CurrentPreset.Filters.Folder.Regex,UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Grid>
                <Button Grid.Column="5"  Content="清空列表" Command="{Binding ClearFileCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonDanger}"></Style>
                    </Button.Style>
                </Button>
            </Grid>
            <!-- 文件列表 -->
            <DataGrid Grid.Row="1"  x:Name="FileDataGrid"  
                      ItemsSource="{Binding Files}"
                      helper:DataGridSelectionHelper.SelectedItems="{Binding SelectedFiles}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="True"
                      VirtualizingStackPanel.IsVirtualizing="True" 
                      VirtualizingPanel.VirtualizationMode="Recycling" 
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      dd:DragDrop.DropHandler="{Binding}"
                      Margin="0,4,0,0" 
                      >
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}">
                        <!-- 解决点击超宽单元格时候水平滚动条跳动定位该单元格的现象 -->
                        <EventSetter Event="RequestBringIntoView" Handler="OnRequestBringIntoView"/>
                    </Style>
                    <Style x:Key="TextOverflowStyle" TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                    </Style>
                </DataGrid.Resources>
                <!-- Row样式 -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                        <Setter Property="Tag" Value="{Binding DataContext, ElementName=FileDataGrid}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <ContextMenu.Style>
                                        <Style TargetType="ContextMenu" BasedOn="{StaticResource  ContextMenu.Small}"></Style>
                                    </ContextMenu.Style>
                                    <!-- 移除文件 -->
                                    <MenuItem Header="移除" 
                                              Command="{Binding PlacementTarget.Tag.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding .}"/>
                                    <MenuItem Header="清空列表" 
                                              Command="{Binding PlacementTarget.Tag.ClearFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding .}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <!-- 触发器 -->
                <i:Interaction.Triggers>
                    <!-- 空白处左键单击-->
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding FileDataGridMouseDownCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <!-- 表格空白处右键菜单 -->
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ContextMenu.Style>
                            <Style TargetType="ContextMenu" BasedOn="{StaticResource  ContextMenu.Small}"></Style>
                        </ContextMenu.Style>
                        <MenuItem Header="移除选中项" Command="{Binding RemoveFileCommand}" />
                        <MenuItem Header="清空列表" Command="{Binding ClearFileCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="状态" Width="60" MinWidth="60" MaxWidth="60" CanUserSort="False" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Enable, UpdateSourceTrigger=PropertyChanged}"  
                                          Command="{Binding DataContext.ToggleFileEnableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" >
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox" BasedOn="{StaticResource CheckBoxBaseStyle}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="2,0,0,0"/>
                                        </Style>
                                    </CheckBox.Style>
                                    <TextBlock Grid.Column="0" >
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
                                                <!-- 默认值 -->
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- 当 NewPathExist 为 True 时 -->
                                                    <DataTrigger Binding="{Binding IsOK}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Text" Value="✔"/>
                                                        <Setter Property="Foreground" Value="#00A000" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Text" Value="❌"/>
                                                        <Setter Property="Foreground" Value="Red" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="新文件名" Width="Auto" MaxWidth="150" MinWidth="50" Binding="{Binding NewName}" CanUserSort="False">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextOverflowStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOK}" Value="True">
                                        <Setter Property="Foreground" Value="#00A000" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                        <Setter Property="Foreground" Value="Red" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="文件名" Width="Auto"  MaxWidth="150" MinWidth="50" Binding="{Binding Name}" IsReadOnly="True" ElementStyle="{StaticResource TextOverflowStyle}" />
                    <DataGridTextColumn Header="扩展名" Width="Auto" MaxWidth="60"  MinWidth="50" Binding="{Binding Ext}" IsReadOnly="True" ElementStyle="{StaticResource TextOverflowStyle}"/>
                    <DataGridTextColumn Header="源路径" Width="Auto"  Binding="{Binding Path}" IsReadOnly="True" ElementStyle="{StaticResource TextOverflowStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <DockPanel Grid.Row="3">
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" />
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="文件总数: " />
                        <TextBlock Text="{Binding Files.Count}" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalContentAlignment="Right" >
                    <StatusBarItem.Style>
                        <Style TargetType="StatusBarItem" BasedOn="{StaticResource StatusBarItemBaseStyle}">
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgressVisible}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!-- 淡出动画 1s 后开始持续0.5s -->
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     BeginTime="0:0:1" 
                                                     To="0" 
                                                     Duration="0:0:0.5" />
                                                <!-- 1.5后隐藏 -->
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:1.5" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!-- 显示时立即出现 -->
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StatusBarItem.Style>
                    <ProgressBar Width="100" Height="15" Value="{Binding ProgressValue}" />
                </StatusBarItem>
            </StatusBar>
            <Grid>
            </Grid>
        </DockPanel>
    </Grid>
</hc:Window>

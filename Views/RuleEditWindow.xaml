<hc:Window x:Class="ReNamer.Views.RuleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReNamer.Views"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:ReNamer.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:RuleEditWindowViewModel, IsDesignTimeCreatable=False}"
        xmlns:converters="clr-namespace:ReNamer.Converters"
        xmlns:rename_engine="clr-namespace:ReNamer.Models.ReName"
        xmlns:controls="clr-namespace:ReNamer.Controls"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        WindowStartupLocation="CenterOwner"
        Icon="/Images/ix--rules-filled.png"
        mc:Ignorable="d"
        Title="{Binding WinTile}" 
        Height="400" Width="500"
        MinHeight="350" MinWidth="400"
        >
    <hc:Window.Resources>
        <!--- 转换器 -->
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibility" />
        <converters:EnumToBooleanConverter x:Key="EnumToBoolean" />

        <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDownBaseStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}"></Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="hc:TextBox" BasedOn="{StaticResource TextBoxPlusBaseStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButtonBaseStyle}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}"></Style>
        <Style TargetType="TabControl" BasedOn="{StaticResource TabControlBaseStyle}"></Style>
        <Style TargetType="TabItem" BasedOn="{StaticResource TabItemStyle}"></Style>
    </hc:Window.Resources>
    <i:Interaction.Triggers>
        <i:KeyTrigger Key="Enter">
            <i:InvokeCommandAction Command="{Binding EnterPressedCommand}" />
        </i:KeyTrigger>
        <i:KeyTrigger Key="Esc">
            <i:InvokeCommandAction Command="{Binding CancelCommand}" />
        </i:KeyTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="8" >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TabControl Grid.Row="0" SelectedIndex="{Binding CurrentTabIndex}" TabStripPlacement="Left" >
            <TabItem Header="插入">
                <hc:ScrollViewer>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10,10,10,0">
                            <hc:TextBox 
                                Text="{Binding CurrentRule.Content,UpdateSourceTrigger=PropertyChanged}"
                                hc:InfoElement.Title="插入："
                                hc:InfoElement.TitlePlacement="Left"
                                hc:InfoElement.Placeholder="输入要插入的内容"
                                hc:InfoElement.ShowClearButton="True"
                                />
                        </Grid>
                        <Grid Grid.Row="1" Margin="10,6,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="位置：" Margin="0,0,6,0"/>
                            <RadioButton Grid.Row="0" Grid.Column="1"  Content="前缀"  GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Prefix}"  />
                            <RadioButton Grid.Row="1" Grid.Column="1" Content="后缀" GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Suffix}" />
                            <Grid Grid.Row="2" Grid.Column="1" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" Content="位置" GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Index}"  Margin="0,0,60,0"/>
                                <hc:NumericUpDown Grid.Column="1" Value="{Binding CurrentRule.AnchorIndex}" />
                                <CheckBox  Grid.Column="2"  Margin="8,0,0,0" Content="从左到右" IsChecked="{Binding CurrentRule.ReverseIndex}" />
                            </Grid>
                            <Grid Grid.Row="3" Grid.Column="1" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" Content="到文本后：" GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=After}" Margin="0,0,24,0"/>
                                <hc:TextBox Grid.Column="1" 
                                            Text="{Binding CurrentRule.AfterAnchorText,UpdateSourceTrigger=PropertyChanged}" 
                                            hc:InfoElement.Placeholder="输入匹配内容"
                                            hc:InfoElement.ShowClearButton="True"/>
                            </Grid>
                            <Grid Grid.Row="4" Grid.Column="1" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" Content="到文本前：" GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Before}" Margin="0,0,24,0"/>
                                <hc:TextBox Grid.Column="1" 
                                         Text="{Binding CurrentRule.BeforeAnchorText,UpdateSourceTrigger=PropertyChanged}"
                                         hc:InfoElement.Placeholder="输入匹配内容"
                                         hc:InfoElement.ShowClearButton="True"/>
                            </Grid>
                            <RadioButton Grid.Row="5" Grid.Column="1" Content="替换当前名称" GroupName="InsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Replace}"/>
                            <CheckBox Grid.Row="6" Grid.Column="1" Content="忽略大小写" IsChecked="{Binding CurrentRule.IgnoreCase}"/>
                            <CheckBox Grid.Row="7" Grid.Column="1" Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}"/>
                        </Grid>
                    </Grid>
                </hc:ScrollViewer>
            </TabItem>
            <TabItem Header="替换">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,10,10,0">
                        <hc:TextBox 
                                Text="{Binding CurrentRule.Match,UpdateSourceTrigger=PropertyChanged}"
                                hc:InfoElement.Title="查找："
                                hc:InfoElement.TitlePlacement="Left"
                                hc:InfoElement.Placeholder="输入要查询内容"
                                hc:InfoElement.ShowClearButton="True" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="10,6,10,0">
                        <hc:TextBox 
                                Text="{Binding CurrentRule.ReplaceTo,UpdateSourceTrigger=PropertyChanged}" 
                                hc:InfoElement.Title="替换："
                                hc:InfoElement.TitlePlacement="Left"
                                hc:InfoElement.Placeholder="输入替换结果"
                                hc:InfoElement.ShowClearButton="True"/>
                    </Grid>
                    <Grid Grid.Row="2" Margin="10,6,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="范围：" Margin="0,0,6,0" />
                        <RadioButton Grid.Row="0" Grid.Column="1"  Content="全部" GroupName="ReplaceMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=All}"/>
                        <RadioButton Grid.Row="1" Grid.Column="1"  Content="首个" GroupName="ReplaceMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=First}"/>
                        <RadioButton Grid.Row="2" Grid.Column="1"  Content="末个" GroupName="ReplaceMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=Last}"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" Content="忽略大小写" IsChecked="{Binding CurrentRule.IgnoreCase}"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="移除">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,10,10,0">
                        <TextBox Text="{Binding CurrentRule.Match,UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxExtend}" 
                                 hc:InfoElement.Title="查找："
                                 hc:InfoElement.TitlePlacement="Left"
                                 hc:InfoElement.Placeholder="输入要移除的内容"
                                 hc:InfoElement.ShowClearButton="True"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="10,6,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                            <RowDefinition MaxHeight="32"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="范围：" Margin="0,0,6,0"/>
                        <RadioButton Grid.Row="0" Grid.Column="1"  Content="全部" GroupName="RemoveMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=All}"/>
                        <RadioButton Grid.Row="1" Grid.Column="1"  Content="首个" GroupName="RemoveMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=First}"/>
                        <RadioButton Grid.Row="2" Grid.Column="1"  Content="末个" GroupName="RemoveMatchRange" IsChecked="{Binding CurrentRule.Range,Converter={StaticResource EnumToBoolean},ConverterParameter=Last}"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" Content="忽略大小写" IsChecked="{Binding CurrentRule.IgnoreCase}"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="序列化">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0" Margin="10,10,5,10" Header="插入位置">
                        <hc:ScrollViewer>
                            <Grid  Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>
                                <RadioButton Grid.Row="0" Content="前缀" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Prefix}" />
                                <RadioButton Grid.Row="1" Content="后缀" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Suffix}" />
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0" Content="位置" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Index}" Margin="0,0,46,0"/>
                                    <hc:NumericUpDown Grid.Column="1" Value="{Binding CurrentRule.AnchorIndex}" />
                                    <CheckBox Grid.Column="2"  Margin="4,0,0,0" Content="从左到右" IsChecked="{Binding CurrentRule.ReverseIndex}" />
                                </Grid>
                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="128"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0" Content="到文本后：" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=After}"  Margin="0,0,10,0"/>
                                    <hc:TextBox Grid.Column="1" 
                                                Text="{Binding CurrentRule.AfterAnchorText,UpdateSourceTrigger=PropertyChanged}"
                                                hc:InfoElement.Placeholder="输入匹配内容"
                                                hc:InfoElement.ShowClearButton="True"/>
                                </Grid>
                                <Grid Grid.Row="4" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="128"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0" Content="到文本前：" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Before}" Margin="0,0,10,0"/>
                                    <hc:TextBox Grid.Column="1" 
                                                Text="{Binding CurrentRule.BeforeAnchorText,UpdateSourceTrigger=PropertyChanged}"
                                                hc:InfoElement.Placeholder="输入匹配内容"
                                                hc:InfoElement.ShowClearButton="True"/>
                                </Grid>
                                <RadioButton Grid.Row="5"  Content="替换当前名称" GroupName="SerializeInsertPosGroup" IsChecked="{Binding CurrentRule.Position,Converter={StaticResource EnumToBoolean},ConverterParameter=Replace}"/>
                                <CheckBox Grid.Row="6" Content="忽略大小写" IsChecked="{Binding CurrentRule.IgnoreCase}"/>
                                <CheckBox Grid.Row="7" Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}"/>
                            </Grid>
                        </hc:ScrollViewer>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Margin="5,10,10,10" Header="序列配置">
                        <Grid  Margin="4" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <hc:NumericUpDown Value="{Binding CurrentRule.SequenceStart}" 
                                                  Style="{StaticResource NumericUpDownExtend}" 
                                                  hc:InfoElement.Title="起始："
                                                  hc:InfoElement.TitlePlacement="Left"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Grid.Row="1">
                                <hc:NumericUpDown Value="{Binding CurrentRule.SequenceStep}" 
                                                  Style="{StaticResource NumericUpDownExtend}" 
                                                  hc:InfoElement.Title="步长："
                                                  hc:InfoElement.TitlePlacement="Left"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Grid.Row="2">
                                <hc:NumericUpDown Value="{Binding CurrentRule.PaddingCount}" Minimum="-1"
                                                  Style="{StaticResource NumericUpDownExtend}" 
                                                  hc:InfoElement.Title="补零："
                                                  hc:InfoElement.TitlePlacement="Left"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                            <CheckBox Grid.Row="3" Content="文件夹变更时重置" IsChecked="{Binding CurrentRule.ResetFolderChanges}" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="填充">
                <hc:ScrollViewer>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Margin="10,10,10,5" Header="补零填充">
                            <Grid Margin="4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition MaxWidth="100"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Content="填充长度：" IsChecked="{Binding CurrentRule.ZeroPadding.Enable}"  />
                                    <hc:NumericUpDown Grid.Column="1" Value="{Binding CurrentRule.ZeroPadding.Length}" />
                                </Grid>
                                <CheckBox Grid.Row="1" Content="移除补零" IsChecked="{Binding CurrentRule.RemoveZeroPadding}"  />
                            </Grid>
                        </GroupBox>
                        <GroupBox Grid.Row="1" Margin="10,5,10,5" Header="文本填充">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition MaxWidth="100"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Content="文本填充长度：" IsChecked="{Binding CurrentRule.TextPadding.Enable}"/>
                                    <hc:NumericUpDown Grid.Column="1" Value="{Binding CurrentRule.TextPadding.Length}" />
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition MaxWidth="146"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="填充内容："/>
                                    <hc:TextBox Grid.Column="1" 
                                                Text="{Binding CurrentRule.TextPadding.Character,UpdateSourceTrigger=PropertyChanged}" 
                                                hc:InfoElement.Placeholder="输入填充内容"
                                                hc:InfoElement.ShowClearButton="True"/>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="填充方向："/>
                                    <RadioButton Grid.Column="1" Content="左" GroupName="FillPaddingDirection" IsChecked="{Binding CurrentRule.TextPadding.Direction,Converter={StaticResource EnumToBoolean},ConverterParameter=Left}" VerticalAlignment="Center"/>
                                    <RadioButton Grid.Column="2" Content="右" GroupName="FillPaddingDirection" IsChecked="{Binding CurrentRule.TextPadding.Direction,Converter={StaticResource EnumToBoolean},ConverterParameter=Right}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </Grid>
                        </GroupBox>
                        <CheckBox Grid.Row="2" Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}" Margin="20,6,10,0"/>
                    </Grid>
                </hc:ScrollViewer>
            </TabItem>
            <TabItem Header="正则">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,10,10,0">
                        <hc:TextBox Text="{Binding CurrentRule.Regex, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Title="表达式："
                                    hc:InfoElement.TitlePlacement="Left"
                                    hc:InfoElement.Placeholder="输入正则表达式"
                                    hc:InfoElement.ShowClearButton="True"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="10,6,10,0" >
                        <hc:TextBox Grid.Column="1" Text="{Binding CurrentRule.ReplaceTo, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Title="替换为："
                                    hc:InfoElement.TitlePlacement="Left"
                                    hc:InfoElement.Placeholder="输入替换表达式"
                                    hc:InfoElement.ShowClearButton="True"/>
                    </Grid>
                    <Grid Grid.Row="2"  Margin="68,6,0,0">
                        <CheckBox Content="忽略大小写" IsChecked="{Binding CurrentRule.IgnoreCase}" />
                    </Grid>
                    <Grid Grid.Row="3"  Margin="68,6,0,10">
                        <CheckBox Content="忽略扩展名" IsChecked="{Binding CurrentRule.IgnoreExt}" />
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="扩展名">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,6,10,0">
                        <hc:TextBox Text="{Binding CurrentRule.Extension, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"
                                 hc:InfoElement.Title="新扩展名 (无需.)"  
                                 hc:InfoElement.Placeholder="输入新扩展名（无需添加 .）"
                                 hc:InfoElement.ShowClearButton="True"/>
                    </Grid>
                    <Grid Grid.Row="1"  Margin="18,6,0,0">
                        <CheckBox Content="忽略扩展名"  VerticalContentAlignment="Center" IsChecked="{Binding CurrentRule.IgnoreExt,UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="添加规则" Command="{Binding AddRuleCommand}" 
                    Style="{StaticResource ButtonPrimary}" 
                    HorizontalAlignment="Stretch" 
                    Visibility="{Binding Mode,Converter={StaticResource EnumToVisibility},ConverterParameter=Add}" 
                     >
            </Button>
            <Button Grid.Column="0" Content="保存规则" Command="{Binding SaveRuleCommand}" 
                    Style="{StaticResource ButtonSuccess}" 
                    HorizontalAlignment="Stretch" 
                    Visibility="{Binding Mode, Converter={StaticResource EnumToVisibility}, ConverterParameter=Edit}" 
                     >
            </Button>
            <Button Grid.Column="1" Content="取消" Command="{Binding CancelCommand}"
                    Style="{StaticResource ButtonDefault}" 
                    Margin="6,0,0,0"
                    HorizontalAlignment="Stretch" 
                    />
        </Grid>
    </Grid>
</hc:Window>
